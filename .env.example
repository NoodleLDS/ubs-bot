# ══════════════════════════════════════════════════
# BOT UBS — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════

# Token de acesso da WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=seu_token_aqui

# ID do número de telefone (Meta for Developers)
WHATSAPP_PHONE_ID=seu_phone_id_aqui

# Token de verificação do webhook (você que define, use no painel da Meta)
WEBHOOK_VERIFY_TOKEN=seu_verify_token_aqui

# App Secret (Configurações > Básico no painel da Meta)
WHATSAPP_APP_SECRET=seu_app_secret_aqui

# Senha para os endpoints /admin/*
ADMIN_TOKEN=sua_senha_admin_aqui

# Caminho do banco de dados SQLite (no Render: /data/bot_ubs.db)
# DB_PATH=./bot_ubs.db
