# Token de acesso 
WHATSAPP_TOKEN=

# ID do número de telefone
WHATSAPP_PHONE_ID=

# Token de verificação do webhook (você que define, vai usar na Meta)
WEBHOOK_VERIFY_TOKEN=

# App Secret (opcional por enquanto - pegar depois em Configurações > Básico)
WHATSAPP_APP_SECRET=

# Senha para endpoints admin
ADMIN_TOKEN=
